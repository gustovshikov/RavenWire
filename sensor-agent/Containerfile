FROM docker.io/library/golang:1.26.2-trixie AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /sensor-agent ./cmd/sensor-agent

FROM docker.io/library/debian:13-slim

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends ca-certificates iproute2 \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /sensor-agent /usr/local/bin/sensor-agent

ENTRYPOINT ["/usr/local/bin/sensor-agent"]
